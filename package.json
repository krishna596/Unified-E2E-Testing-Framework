{
  "name": "hybrid-e2e-framework",
  "version": "1.0.0",
  "description": "Hybrid E2E testing framework supporting Web (Playwright) and Mobile (Appium)",
  "main": "index.js",
  "scripts": {
    "---------- RUN TESTS ----------": "",
    "test:web": "TEST_PLATFORM=web playwright test --headed",
    "test:android": "TEST_PLATFORM=android npx wdio run wdio.conf.ts",
    "test:ios": "TEST_PLATFORM=ios npx wdio run wdio.conf.ts",
    "test:all": "npm run test:web && npm run test:android && npm run test:ios",
    "---------- WEB OPTIONS ----------": "",
    "test:web:headed": "TEST_PLATFORM=web playwright test --headed",
    "test:web:debug": "TEST_PLATFORM=web playwright test --debug",
    "test:web:ui": "TEST_PLATFORM=web playwright test --ui",
    "test:report": "playwright show-report",
    "---------- APPIUM SERVER ----------": "",
    "appium:start": "appium --allow-insecure chromedriver_autodownload",
    "---------- UTILITIES ----------": "",
    "clean": "rm -rf test-results playwright-report allure-results",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "e2e",
    "testing",
    "playwright",
    "appium",
    "webdriverio",
    "mobile",
    "web",
    "hybrid",
    "cross-platform"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.2.3",
    "@wdio/appium-service": "^9.4.5",
    "@wdio/cli": "^9.4.5",
    "@wdio/local-runner": "^9.4.5",
    "@wdio/mocha-framework": "^9.4.4",
    "@wdio/spec-reporter": "^9.4.4",
    "appium": "^2.15.1",
    "appium-uiautomator2-driver": "^3.9.6",
    "appium-xcuitest-driver": "^7.34.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
