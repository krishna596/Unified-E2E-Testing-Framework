{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["e2e/shared/*"]
    },
    "types": ["node", "@wdio/globals/types", "mocha"]
  },
  "include": [
    "e2e/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
